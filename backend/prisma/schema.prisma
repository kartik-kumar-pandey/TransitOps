datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("dispatcher") // e.g. "admin", "dispatcher", "manager"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id                 String           @id @default(uuid())
  registrationNumber String           @unique
  make               String
  model              String
  type               String           @default("Truck") // e.g. "Truck", "Van"
  region             String           @default("North") // e.g. "North", "South"
  odometer           Float            @default(0.0)
  acquisitionCost    Float            @default(0.0)
  year               Int
  status             String           @default("Available") // e.g. "Available", "In Shop"
  capacityWeight     Float
  trips              Trip[]
  maintenanceLogs    MaintenanceLog[]
  fuelLogs           FuelLog[]
  expenses           Expense[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Driver {
  id            String   @id @default(uuid())
  name          String
  licenseNumber String   @unique
  licenseExpiry DateTime
  status        String   @default("Available") // e.g. "Available", "On Trip", "Off Duty"
  safetyScore   Float    @default(100.0)
  trips         Trip[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Trip {
  id            String    @id @default(uuid())
  tripNumber    String    @unique
  vehicleId     String
  vehicle       Vehicle   @relation(fields: [vehicleId], references: [id])
  driverId      String
  driver        Driver    @relation(fields: [driverId], references: [id])
  origin        String
  destination   String
  cargoWeight   Float
  status        String    @default("Scheduled") // e.g. "Scheduled", "Dispatched", "Completed", "Cancelled"
  dispatchedAt  DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model MaintenanceLog {
  id          String    @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
  description String
  cost        Float
  status      String    @default("Open") // e.g. "Open", "Closed"
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model FuelLog {
  id              String   @id @default(uuid())
  vehicleId       String
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])
  fuelAmount      Float
  cost            Float
  odometerReading Float
  loggedAt        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Expense {
  id          String   @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  description String
  amount      Float
  category    String // e.g., "Toll", "Permit", "Fine", "Other"
  loggedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
